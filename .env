#Global:
DRY_RUN=True
EXTRA_FILES=https://github.com/ReVanced/GmsCore/releases/latest@Revanced-Microg.apk
PATCH_APPS=youtube,youtube_extended_red,youtube_extended_blue,youtube_music
GLOBAL_CLI_DL=https://github.com/revanced/revanced-cli/releases/latest-prerelease
GLOBAL_PATCHES_DL=https://github.com/anddea/revanced-patches/releases/latest-prerelease
GLOBAL_PATCHES_JSON_DL=https://github.com/anddea/revanced-patches/releases/latest-prerelease
GLOBAL_INTEGRATIONS_DL=https://github.com/anddea/revanced-integrations/releases/latest-prerelease

#YouTube Extended Red:
YOUTUBE_EXTENDED_RED_VERSION=19.11.38
YOUTUBE_EXTENDED_RED_PACKAGE_NAME=app.red.android.youtube
YOUTUBE_EXTENDED_RED_DL_SOURCE=https://www.apkmirror.com/apk/google-inc/youtube/
YOUTUBE_EXTENDED_RED_OPTIONS_FILE_NAME=options_red.json
YOUTUBE_EXTENDED_RED_KEYSTORE_FILE_NAME=extended.keystore
YOUTUBE_EXTENDED_RED_INCLUDE_PATCH=custom-branding-name-youtube,custom-branding-icon-youtube
SPACE_FORMATTED_PATCHES=

#YouTube Extended Blue:
YOUTUBE_EXTENDED_BLUE_VERSION=19.11.38
YOUTUBE_EXTENDED_BLUE_PACKAGE_NAME=app.blue.android.youtube
YOUTUBE_EXTENDED_BLUE_DL_SOURCE=https://www.apkmirror.com/apk/google-inc/youtube/
YOUTUBE_EXTENDED_BLUE_OPTIONS_FILE_NAME=options_blue.json
YOUTUBE_EXTENDED_BLUE_KEYSTORE_FILE_NAME=extended.keystore
YOUTUBE_EXTENDED_BLUE_INCLUDE_PATCH=custom-branding-name-youtube,custom-branding-icon-youtube

YOUTUBE_MUSIC_VERSION=6.29.58
